{
  "name": "stegosavr",
  "version": "1.0.0",
  "description": "A small vanilla TypeScript single page app.",
  "repository": {
    "type": "git",
    "url": "git@github.com-dvorza:dvorza/stegosavr.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && tsc && vite build",
    "build:wasm": "wasm-pack build wasm-crypto --target web --out-dir ../src/wasm --release",
    "preview": "vite preview",
    "test": "npm run test:wasm && vitest run",
    "test:wasm": "cargo test --manifest-path wasm-crypto/Cargo.toml",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wasm-pack": "^0.15.0"
  }
}
